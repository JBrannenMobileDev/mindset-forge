rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile.
    // Accountability partners can read the primary user's doc if their uid
    // is listed in the partnerUids array (populated by acceptPartnerInvite function).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null
        && resource.data.partnerUids != null
        && request.auth.uid in resource.data.partnerUids;
    }

    // Journal entries belong to their owner (field name is uid, not userId)
    match /journals/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }

    // Chat sessions belong to their owner (field name is uid, not userId)
    match /chat_sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }

    // Partner invites — readable by anyone with the invite ID, writable only by Cloud Functions (admin SDK)
    match /partner_invites/{inviteId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
