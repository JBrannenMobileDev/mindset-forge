rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write ONLY their own profile.
    // Accountability partners do NOT get direct read access to the primary's
    // doc (it holds private data: beliefs, fears, coach memory, etc). Partners
    // read a privacy-curated subset via the getPartnerProgress callable instead.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Journal entries belong to their owner (field name is uid, not userId)
    match /journals/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }

    // Chat sessions belong to their owner (field name is uid, not userId)
    match /chat_sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }

    // Partner invites — fully locked to clients. All reads/writes happen
    // through Cloud Functions (getPartnerInviteInfo / acceptPartnerInvite)
    // using the Admin SDK, which bypasses these rules. The client never
    // touches this collection directly, so deny all direct access.
    match /partner_invites/{inviteId} {
      allow read, write: if false;
    }

    // Viral metrics — written only by Cloud Functions (Admin SDK).
    match /viral_metrics/{docId} {
      allow read, write: if false;
    }
  }
}
