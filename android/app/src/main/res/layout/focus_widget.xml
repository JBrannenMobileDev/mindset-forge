<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/focus_widget_background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/focus_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TODAY'S FOCUS"
            android:textColor="@color/widgetTextMuted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/focus_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/focus_widget_streak_chip"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="🔥 0"
            android:textColor="@color/widgetWarning"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/focus_accent"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:background="@drawable/focus_widget_accent_bar" />

        <TextView
            android:id="@+id/focus_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Set your #1 focus for today"
            android:textColor="@color/widgetTextPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.1"
            android:maxLines="3"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- 7-day streak chain — only shown in the focus-complete (done) state. -->
    <LinearLayout
        android:id="@+id/focus_week_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/focus_day_label_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widgetTextMuted"
                android:textSize="9sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/focus_day_0"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:background="@drawable/focus_widget_day_empty"
                android:textColor="@color/widgetOnPrimary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/focus_day_label_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widgetTextMuted"
                android:textSize="9sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/focus_day_1"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:background="@drawable/focus_widget_day_empty"
                android:textColor="@color/widgetOnPrimary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/focus_day_label_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widgetTextMuted"
                android:textSize="9sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/focus_day_2"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:background="@drawable/focus_widget_day_empty"
                android:textColor="@color/widgetOnPrimary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/focus_day_label_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widgetTextMuted"
                android:textSize="9sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/focus_day_3"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:background="@drawable/focus_widget_day_empty"
                android:textColor="@color/widgetOnPrimary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/focus_day_label_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widgetTextMuted"
                android:textSize="9sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/focus_day_4"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:background="@drawable/focus_widget_day_empty"
                android:textColor="@color/widgetOnPrimary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/focus_day_label_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widgetTextMuted"
                android:textSize="9sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/focus_day_5"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:background="@drawable/focus_widget_day_empty"
                android:textColor="@color/widgetOnPrimary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/focus_day_label_6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widgetTextMuted"
                android:textSize="9sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/focus_day_6"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:background="@drawable/focus_widget_day_empty"
                android:textColor="@color/widgetOnPrimary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/focus_week_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/widgetTextSecondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="gone" />

    <Button
        android:id="@+id/focus_button"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/focus_widget_button"
        android:text="Mark done"
        android:textAllCaps="false"
        android:textColor="@color/widgetOnPrimary"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
